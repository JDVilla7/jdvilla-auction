{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/owner", "dest": "/public/owner.html" },
    { "src": "/", "dest": "/public/owner.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
